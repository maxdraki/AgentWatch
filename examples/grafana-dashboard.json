{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for AgentWatch metrics",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "AgentWatch — AI Agent Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(agentwatch_agent_info)",
          "legendFormat": "Agents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Traces",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "sum(agentwatch_traces_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "avg(agentwatch_error_rate_pct)",
          "legendFormat": "Error Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(agentwatch_cost_usd_total)",
          "legendFormat": "Cost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Avg Trace Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "avg(agentwatch_trace_duration_seconds_avg)",
          "legendFormat": "Duration"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "min(agentwatch_health_status)",
          "legendFormat": "Worst Health"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } },
            { "type": "value", "options": { "0.5": { "text": "WARN", "color": "yellow" } } },
            { "type": "value", "options": { "0": { "text": "CRITICAL", "color": "red" } } },
            { "type": "value", "options": { "-1": { "text": "UNKNOWN", "color": "gray" } } }
          ]
        }
      }
    },
    {
      "title": "Traces by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "agentwatch_traces_total{status=\"completed\"}",
          "legendFormat": "{{ agent }} (completed)"
        },
        {
          "expr": "agentwatch_traces_total{status=\"failed\"}",
          "legendFormat": "{{ agent }} (failed)"
        }
      ]
    },
    {
      "title": "Error Rate by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "agentwatch_error_rate_pct",
          "legendFormat": "{{ agent }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Health Check Status",
      "type": "state-timeline",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "agentwatch_health_status",
          "legendFormat": "{{ agent }} / {{ check }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } },
            { "type": "value", "options": { "0.5": { "text": "WARN", "color": "yellow" } } },
            { "type": "value", "options": { "0": { "text": "CRITICAL", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Cost by Model",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "agentwatch_cost_usd_total",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "title": "Token Usage by Direction",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "sum by (direction) (agentwatch_tokens_total)",
          "legendFormat": "{{ direction }}"
        }
      ]
    },
    {
      "title": "Health Check Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "agentwatch_health_duration_seconds",
          "legendFormat": "{{ agent }} / {{ check }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Logs by Level",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (level) (agentwatch_logs_total)",
          "legendFormat": "{{ level }}"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }] }
        ]
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentwatch", "ai", "agents", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "AgentWatch — AI Agent Observability",
  "uid": "agentwatch-main",
  "version": 1
}
